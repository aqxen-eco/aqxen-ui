// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  actor     String   @unique
  name      String?  @map("name")
  location  String?  @map("location")
  interests String?  @map("interests")
  about      String?  @map("about")
  avatarIpfs String?  @map("avatar_ipfs")
  coverIpfs      String?  @map("cover_ipfs")
  pinataGroupId    String?  @map("pinata_group_id")
  avatarUploadCount Int     @default(0) @map("avatar_upload_count")
  coverUploadCount  Int     @default(0) @map("cover_upload_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts   Post[]
  mention Mention[]

  @@map("user")
}

model Post {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  content     String
  badgeSymbol  String[] @default([]) @map("badge_symbol")
  organization String?  @map("organization")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  parent   Post?     @relation("PostToParent", fields: [parentId], references: [id])
  parentId String?   @map("parent_id")
  children Post[]    @relation("PostToParent")
  mention  Mention[]

  @@map("post")
}

model Mention {
  id     String @id @default(uuid())
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String @map("post_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@map("mention")
}

model PinataGroup {
  id            String   @id @default(uuid())
  name          String   @unique
  pinataGroupId String   @map("pinata_group_id")
  uploadCount   Int      @default(0) @map("upload_count")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("pinata_group")
}
