// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  actor     String   @unique
  name      String?  @map("name")
  location  String?  @map("location")
  interests String?  @map("interests")
  about      String?  @map("about")
  avatarIpfs String?  @map("avatar_ipfs")
  coverIpfs      String?  @map("cover_ipfs")
  pinataGroupId    String?  @map("pinata_group_id")
  avatarUploadCount Int     @default(0) @map("avatar_upload_count")
  coverUploadCount  Int     @default(0) @map("cover_upload_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts   Post[]
  mention Mention[]

  @@map("user")
}

model Post {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  content     String
  badgeSymbol  String[] @default([]) @map("badge_symbol")
  organization String?  @map("organization")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  isAnnouncement Boolean @default(false) @map("is_announcement")
  onChainPostId  BigInt? @map("on_chain_post_id")

  parScore   Float @default(0) @map("par_score")
  upaScore   Float @default(0) @map("upa_score")
  gpaScore   Float @default(0) @map("gpa_score")
  rpaScore   Float @default(0) @map("rpa_score")
  totalScore Float @default(0) @map("total_score")

  parent    Post?      @relation("PostToParent", fields: [parentId], references: [id])
  parentId  String?    @map("parent_id")
  children  Post[]     @relation("PostToParent")
  mention   Mention[]
  beamGives BeamGive[]

  @@map("post")
}

model Mention {
  id     String @id @default(uuid())
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String @map("post_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@map("mention")
}

model BeamGive {
  id             String   @id @default(uuid())
  post           Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId         String   @map("post_id")
  giverActor     String   @map("giver_actor")
  recipientActor String   @map("recipient_actor")
  badgeSymbol    String   @map("badge_symbol")
  orgAccount     String   @map("org_account")
  parAmount      Int      @default(0) @map("par_amount")
  upaEmitted     Int      @default(0) @map("upa_emitted")
  gpaEmitted     Float    @default(0) @map("gpa_emitted")
  xyzEmitted     Int      @default(0) @map("xyz_emitted")
  rpaEmitted     Float    @default(0) @map("rpa_emitted")
  trackingDeltas Json     @default("{}") @map("tracking_deltas")
  deltaScore     Int      @default(0) @map("delta_score")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("beam_give")
}

model UniqueGiver {
  id             String @id @default(uuid())
  recipientActor String @map("recipient_actor")
  giverActor     String @map("giver_actor")

  @@unique([recipientActor, giverActor])
  @@map("unique_giver")
}

model SeasonUniqueGiver {
  id             String @id @default(uuid())
  recipientActor String @map("recipient_actor")
  giverActor     String @map("giver_actor")
  seasonId       String @map("season_id")

  @@unique([recipientActor, giverActor, seasonId])
  @@map("season_unique_giver")
}

model UserEmissionTotal {
  id              String @id @default(uuid())
  userActor       String @map("user_actor")
  orgAccount      String @map("org_account")
  beamBadgeSymbol String @map("beam_badge_symbol")
  parTotal        Float  @default(0) @map("par_total")
  upaTotal        Float  @default(0) @map("upa_total")
  gpaTotal        Float  @default(0) @map("gpa_total")
  xyzTotal        Float  @default(0) @map("xyz_total")
  rpaEmittedTotal Float  @default(0) @map("rpa_emitted_total")

  @@unique([userActor, orgAccount, beamBadgeSymbol])
  @@map("user_emission_total")
}

model UserReputationScore {
  id         String   @id @default(uuid())
  userActor  String   @map("user_actor")
  orgAccount String   @map("org_account")
  parScore   Float    @default(0) @map("par_score")
  upaScore   Float    @default(0) @map("upa_score")
  gpaScore   Float    @default(0) @map("gpa_score")
  rpaScore   Float    @default(0) @map("rpa_score")
  totalScore Float    @default(0) @map("total_score")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userActor, orgAccount])
  @@map("user_reputation_score")
}

model PinataGroup {
  id            String   @id @default(uuid())
  name          String   @unique
  pinataGroupId String   @map("pinata_group_id")
  uploadCount   Int      @default(0) @map("upload_count")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("pinata_group")
}
